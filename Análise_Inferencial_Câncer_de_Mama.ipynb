    {
      "cell_type": "markdown",
      "source": [
        "## **Parte 1** - Calculando a Estimação Pontual"
      ],
      "metadata": {
        "id": "PEhI1w-kXXw2"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Estimação Pontual - Trabalhando com a amostra calculada da população do bando de dados\n",
        "n_M = len(amostra_maligno_radius_mean)\n",
        "n_B = len(amostra_benigno_radius_mean)\n",
        "\n",
        "media_M = amostra_maligno_radius_mean.mean()\n",
        "media_B = amostra_benigno_radius_mean.mean()\n",
        "\n",
        "diferenca_pontual = media_M - media_B\n",
        "\n",
        "print(f\"--- ESTIMAÇÃO PONTUAL ---\")\n",
        "print(f\"Número de tumores Malignos sorteados (n_M): {n_M}\")\n",
        "print(f\"Média amostral do raio (Maligno): {media_M:.4f}\")\n",
        "print(f\"\\nNúmero de tumores Benignos sorteados (n_B): {n_B}\")\n",
        "print(f\"Média amostral do raio (Benigno): {media_B:.4f}\")\n",
        "print(f\"\\nEstimativa pontual da diferença entre as médias (Maligno - Benigno): {diferenca_pontual:.4f}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "s8mvsTASS-tV",
        "outputId": "7847aeb9-ce7f-463b-8030-c87989ecad6d"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",

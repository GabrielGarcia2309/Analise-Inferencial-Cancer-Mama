    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import math\n",
        "\n",
        "# 1. Parâmetros iniciais\n",
        "sigma = df[\"radius_mean\"].std()\n",
        "z = 1.96  # Nível de confiança de 95%\n",
        "E = 0.5   # Margem de erro admissível\n",
        "N = len(df)  # Tamanho total da população finita\n",
        "\n",
        "# 2. Cálculo do tamanho inicial da amostra (população infinita)\n",
        "n_calculado = (z * sigma / E) ** 2\n",
        "\n",
        "# 3. Aplicação do Fator de Correção para População Finita (FCPF)\n",
        "# A regra diz para corrigir se a amostra inicial for maior que 5% da população\n",
        "if (n_calculado / N) > 0.05:\n",
        "    n_corrigido = n_calculado / (1 + ((n_calculado - 1) / N))\n",
        "    # Arredondamos sempre para cima, pois não existe \"meia\" observação\n",
        "    n_final = math.ceil(n_corrigido)\n",
        "    print(f\"Amostra corrigida necessária: {n_final} (Reduzida de {math.ceil(n_calculado)} devido à população finita de {N})\")\n",
        "else:\n",
        "    n_final = math.ceil(n_calculado)\n",
        "    print(f\"Amostra necessária: {n_final} (Não houve necessidade de correção, pois representa < 5% de {N})\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "PVZF7RL2imUQ",
        "outputId": "e6a14e59-a216-4b87-fa71-ef2334a4c45a"
